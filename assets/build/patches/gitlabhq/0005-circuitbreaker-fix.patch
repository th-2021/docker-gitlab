diff --git a/lib/gitlab/gitaly_client/circuit_breaker.rb b/lib/gitlab/gitaly_client/circuit_breaker.rb
index 694f951d62531f..bfeeda2fea24fb 100644
--- a/lib/gitlab/gitaly_client/circuit_breaker.rb
+++ b/lib/gitlab/gitaly_client/circuit_breaker.rb
@@ -60,6 +60,8 @@ def check!
       attr_reader :service, :rpc, :storage
 
       def enabled?
+        return false unless Feature::FlipperFeature.table_exists?
+
         Feature.enabled?(:add_circuit_breaker_to_gitaly, Feature.current_request)
       end
 
diff --git a/spec/lib/gitlab/gitaly_client/circuit_breaker_spec.rb b/spec/lib/gitlab/gitaly_client/circuit_breaker_spec.rb
index 3a683dcb7c7fef..83af570dea761c 100644
--- a/spec/lib/gitlab/gitaly_client/circuit_breaker_spec.rb
+++ b/spec/lib/gitlab/gitaly_client/circuit_breaker_spec.rb
@@ -237,4 +237,21 @@
       end
     end
   end
+
+  context 'when database schema is not initialized' do
+    before do
+      allow(Feature::FlipperFeature).to receive(:table_exists?).and_return(false)
+    end
+
+    it 'disables circuit breaker to avoid database errors' do
+      # Verifies fix for https://gitlab.com/gitlab-org/gitlab/-/issues/591292
+      # During `gitlab:setup` on a fresh database, Feature.enabled? would raise
+      # ActiveRecord::StatementInvalid because the feature_gates table doesn't exist.
+      # The table_exists? check prevents this by disabling the circuit breaker early.
+      expect(Feature).not_to receive(:enabled?)
+
+      expect { circuit_breaker.call { 'success' } }.not_to raise_error
+      expect { circuit_breaker.check! }.not_to raise_error
+    end
+  end
 end
